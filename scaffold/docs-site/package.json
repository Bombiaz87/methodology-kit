{
  "name": "docs-site",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Doc site (Astro + Starlight): renderer for the docs/ documentation, auto-rebuild via chokidar watcher.",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 3004",
